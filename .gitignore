__pycache__/
*.pyc
*.pyo
*.egg-info/
.DS_Store
/build/
.env
.env.local
.env.*.local
credentials/
token.pickle
*.pickle.lock
.pytest_cache/
.mypy_cache/
promo/remotion/node_modules/
promo/remotion/out/
promo/remotion/props.json
promo/remotion/props_*.json
promo/remotion/public/clip_*.mp4

# Raw input material: clips supplied by the operator per POI.
# Never commit real material to the repo. Only the top-level scaffold
# (README.md + .gitkeep) is tracked so the convention survives a fresh clone.
/material/*
!/material/README.md
!/material/.gitkeep

# Rendered promo outputs from local runs.
/output/

# Production preview specs/logs/retrieval dumps generated by batch runs.
/runs/

# Per-session Claude Code runtime state (sprint-gate flags, local agent memory).
.claude/

# Generated view of architecture.md — regenerated via
# `python3 -m promo.cli.render_architecture`. The .md is the source of
# truth; the HTML is a local-viewing convenience and must stay out of git.
/architecture.html

# Fresh-venv install scratch (when fresh-venv smoke runs in-tree).
/.venv/
