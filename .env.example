# --- Required vendor credentials ---
OPENROUTER_API_KEY=     # MiMo clip analysis + OpenAI text-embedding-3-small
GEMINI_API_KEY=         # Gemini #1 (script) + Gemini #2 (clip-assign) + Gemini TTS
ELEVENLABS_API_KEY=     # ElevenLabs TTS (alternate backend; required only if voice routes there)

# --- Optional knobs ---

# Gemini model for script + assigner.
GEMINI_MODEL=gemini-2.5-pro

# MiMo Omni model id on OpenRouter. Bumping invalidates `material/<slug>/.mimo_cache/`.
PROMO_CLIP_MODEL=xiaomi/mimo-v2-omni

# Remotion render concurrency (parallel Chromium tabs per render). Default 2.
PROMO_RENDER_CONCURRENCY=2

# Format selector — "single" (default; pin from --target-duration-sec) or "random"
# (sample from arsenal/script_skeletons/*.yaml per variant).
PROMO_FORMAT_SELECTOR=single

# compile_promo CLI defaults.
PROMO_DEFAULT_DURATION_SEC=30
PROMO_DEFAULT_VARIANTS=1
PROMO_DEFAULT_SCRIPT_CANDIDATES=1
