# --- Required vendor credentials ---
OPENROUTER_API_KEY=     # MiMo clip analysis + OpenAI text-embedding-3-small
GEMINI_API_KEY=         # Gemini #1 (script) + Gemini #2 (clip-assign) + Gemini TTS
ELEVENLABS_API_KEY=     # ElevenLabs TTS (alternate backend; required only if voice routes there)

# Google Drive OAuth for final MP4 uploads. Reuse the AIGC OAuth
# client_secret.json and token.pickle for MVP.
GOOGLE_CREDENTIALS_FILE=
PGC_GOOGLE_TOKEN_FILE=
PGC_DRIVE_PARENT_FOLDER_ID=
PGC_DRIVE_PARENT_FOLDER_NAME=AIGC Production Masters

# Required only when final-video upscale is enabled for low-res transition runs.
# The referenced env file must provide WAVESPEED_API_KEY.
PGC_WAVESPEED_UPSCALE_COMMAND=
# WaveSpeed source upload: supabase = private staging bucket + signed URL
# (needs SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY in the env; anon keys are
# rejected — they cannot write Storage), temp = legacy PUBLIC temp hosts,
# auto = supabase when credentials exist else temp.
# PRODUCTION must use supabase (fail closed — never expose unreleased
# masters on public hosts); auto/temp are for local smoke only.
PGC_WAVESPEED_SOURCE_HOST=supabase
PGC_WAVESPEED_STAGING_BUCKET=pgc-upscale-staging

# --- Optional knobs ---

# Gemini model for script + assigner.
GEMINI_MODEL=gemini-2.5-pro

# MiMo Omni model id on OpenRouter. Bumping invalidates `material/<slug>/.mimo_cache/`.
PROMO_CLIP_MODEL=xiaomi/mimo-v2-omni

# Remotion render concurrency (parallel Chromium tabs per render). Default 2.
PROMO_RENDER_CONCURRENCY=2

# Format selector — "single" (default; pin from --target-duration-sec) or "random"
# (sample from arsenal/script_skeletons/*.yaml per variant).
PROMO_FORMAT_SELECTOR=single

# compile_promo CLI defaults.
PROMO_DEFAULT_DURATION_SEC=30
PROMO_DEFAULT_VARIANTS=1
PROMO_DEFAULT_SCRIPT_CANDIDATES=1
